# ============================================
# LUN'DRIVE - Configuration de sécurité
# ============================================

# Désactiver l'affichage des dossiers (indexation)
Options -Indexes

# Activer le moteur de réécriture
RewriteEngine On

# Rediriger les erreurs 404 vers la page d'accueil
ErrorDocument 404 /file_manager/index.php

# Protéger les fichiers PHP sensibles (fichiers individuels)
<FilesMatch "^(config|auth|session|database)\.php$">
    Require all denied
</FilesMatch>

# Protéger les fichiers de configuration
<Files "database.php">
    Require all denied
</Files>

<Files "auth.php">
    Require all denied
</Files>

<Files "session.php">
    Require all denied
</Files>

# Sécuriser les cookies
php_flag session.cookie_httponly on
php_flag session.cookie_secure off
php_flag session.use_only_cookies on

# Limiter la taille d'upload (20 Mo max)
php_value upload_max_filesize 20M
php_value post_max_size 20M
php_value max_execution_time 300
